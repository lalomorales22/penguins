{
  "id": "self-journal",
  "kind": "utility",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "reflectEveryNTurns": {
        "type": "number",
        "minimum": 1,
        "maximum": 100,
        "default": 10
      },
      "selfPath": {
        "type": "string",
        "description": "Absolute path to SELF.md (defaults to {workspaceDir}/memory/SELF.md)"
      }
    }
  }
}
